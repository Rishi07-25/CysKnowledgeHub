# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas (development)
# Fill in your Atlas cluster credentials below.
# The URI is constructed automatically from these two values.
MONGODB_USERNAME=<db_username>
MONGODB_PASSWORD=<db_password>
# Alternatively, you can override the full URI directly:
# MONGO_URI=mongodb+srv://<db_username>:<db_password>@cysknowledgehub.sxc3yvo.mongodb.net/<db_name>?appName=Cysknowledgehub

# IMPORTANT (multi-dev): set this to a unique database name per developer,
# e.g. cybershield_gokul, cybershield_alice. This isolates your Firebase UIDs
# from teammates who use different Firebase projects on the same Atlas cluster.
# All databases live on the shared cluster — no extra cost.
MONGODB_DATABASE=cybershield_<yourname>

# Firebase Admin — download a service account key from:
# Firebase Console → Project Settings → Service Accounts → Generate new private key
# and save it as backend/config/serviceAccountKey.json
FIREBASE_SERVICE_ACCOUNT_PATH=./config/serviceAccountKey.json

# Allowed frontend origin for CORS
CLIENT_ORIGIN=http://localhost:3000

# ImageKit.io — Media CDN (optional but recommended for production)
# 1. Create a free account at https://imagekit.io
# 2. Go to Dashboard → Developer options → API keys
# 3. Fill in the three values below.
# If NOT set, the server stores uploaded images on local disk (uploads/ folder).
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/<your_imagekit_id>
